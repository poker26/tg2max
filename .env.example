# Telegram client (GramJS)
TG_API_ID=
TG_API_HASH=
TG_SESSION=
TG_IMPORT_LIMIT=200
TELEGRAM_SOURCE_CHANNEL=@yourchannel

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# For migrations (choose one option)
SUPABASE_DATABASE_URL=
# DB_HOST=
# DB_PORT=6543
# DB_USER=
# DB_PASSWORD=
# DB_NAME=postgres

# MinIO (for media relay)
# Нужен для кросспоста с фото: изображение берется из MinIO, затем загружается в MAX.
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET_MEDIA=tg2max-media

# Max Bot API (platform-api.max.ru)
MAX_BOT_TOKEN=
MAX_TARGET_CHAT_ID=
MAX_API_BASE_URL=https://platform-api.max.ru
MAX_POST_DELAY_MS=5000
